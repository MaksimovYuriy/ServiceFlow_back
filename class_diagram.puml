@startuml ServiceFlow Class Diagram

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 14
skinparam linetype ortho

' ===== MODELS =====
package "Models" {

  class User {
    - id : integer
    - email : string
    - password_digest : string
    - phone : string
    - active : boolean
    - created_at : datetime
    - updated_at : datetime
    --
    + has_secure_password
    + generate_jwt() : String
    + {static} from_jwt(token) : User
    .. callbacks ..
    downcase_email (before_save)
    .. validations ..
    email: presence, uniqueness
  }

  class Master {
    - id : integer
    - phone : string
    - first_name : string
    - middle_name : string
    - last_name : string
    - salary : integer
    - active : boolean
    - created_at : datetime
    - updated_at : datetime
    --
    .. validations ..
    first_name: presence
    last_name: presence
    phone: presence, uniqueness
  }

  class MasterSchedule {
    - id : integer
    - master_id : integer
    - weekday : integer
    - start_time : time
    - end_time : time
    - created_at : datetime
    - updated_at : datetime
    --
    + start_time_hh_mm() : String
    + end_time_hh_mm() : String
    .. validations ..
    weekday in 0..6
    end_after_start
    no_overlap
  }

  class Service {
    - id : integer
    - title : string
    - description : text
    - duration : string
    - price : integer
    - active : boolean
    - created_at : datetime
    - updated_at : datetime
    --
    .. validations ..
    title: presence
    price: presence, > 0
    duration: presence
  }

  class Client {
    - id : integer
    - full_name : string
    - phone : string
    - telegram : string
    - created_at : datetime
    - updated_at : datetime
    --
    .. validations ..
    full_name: presence
    phone: presence, uniqueness
  }

  class Note <<Booking>> {
    - id : integer
    - status : integer
    - total_price : float
    - service_id : integer
    - client_id : integer
    - master_id : integer
    - start_at : datetime
    - end_at : datetime
    - created_at : datetime
    - updated_at : datetime
    --
    .. enum status ..
    pending = 0
    canceled = 1
    completed = 2
    .. scopes ..
    + actuals()
    .. validations ..
    start_at: presence
    end_at: presence
    end_after_start
    no_overlap (per master)
  }

  class Material {
    - id : integer
    - title : string
    - quantity : integer
    - minimal_quantity : integer
    - price : float
    - created_at : datetime
    - updated_at : datetime
    --
    .. validations ..
    title: presence
    quantity: >= 0
    minimal_quantity: >= 0
    price: >= 0
  }

  class MaterialOperation {
    - id : integer
    - amount : integer
    - operation_type : integer
    - status : integer
    - source : integer
    - material_id : integer
    - note_id : integer
    - created_at : datetime
    - updated_at : datetime
    --
    .. enum operation_type ..
    in = 0
    out = 1
    .. enum status ..
    pending = 0
    applied = 1
    cancelled = 2
    .. enum source ..
    manual = 0
    booking = 1
    .. validations ..
    amount: > 0
  }

  class ServiceMaterial <<Join>> {
    - id : integer
    - required_quantity : integer
    - service_id : integer
    - material_id : integer
    - created_at : datetime
    - updated_at : datetime
    --
    .. validations ..
    required_quantity: presence, > 0
  }

  class ServiceMaster <<Join>> {
    - id : integer
    - service_id : integer
    - master_id : integer
    - created_at : datetime
    - updated_at : datetime
    --
    .. validations ..
    service_id: unique per master_id
  }
}

' ===== MODEL ASSOCIATIONS =====
Master "1" --> "*" MasterSchedule : has_many\n(dependent: destroy)
Master "1" --> "*" ServiceMaster : has_many\n(dependent: destroy)
Master "1" --> "*" Note : has_many\n(dependent: restrict)

Service "1" --> "*" ServiceMaterial : has_many\n(dependent: destroy)
Service "1" --> "*" ServiceMaster : has_many\n(dependent: destroy)
Service "1" --> "*" Note : has_many\n(dependent: restrict)

Client "1" --> "*" Note : has_many\n(dependent: restrict)

Note "*" --> "1" Service : belongs_to
Note "*" --> "1" Client : belongs_to
Note "*" --> "1" Master : belongs_to
Note "1" --> "*" MaterialOperation : has_many\n(dependent: nullify)

ServiceMaterial "*" --> "1" Service : belongs_to
ServiceMaterial "*" --> "1" Material : belongs_to

ServiceMaster "*" --> "1" Service : belongs_to
ServiceMaster "*" --> "1" Master : belongs_to

Material "1" --> "*" ServiceMaterial : has_many\n(dependent: destroy)
Material "1" --> "*" MaterialOperation : has_many\n(dependent: destroy)
MaterialOperation "*" --> "1" Material : belongs_to
MaterialOperation "*" --> "0..1" Note : belongs_to\n(optional)


' ===== SERVICES =====
package "Services" {

  class JwtService <<Service>> {
    - {static} SECRET_KEY : String
    - {static} ALGORITHM : String = "HS256"
    - {static} DEFAULT_EXPIRY : Duration = 12h
    --
    + {static} encode(**data) : String
    + {static} decode(token) : Hash
    + {static} decode_silent(token) : Hash?
  }

  class SignInService <<Service>> {
    - email : String
    - password : String
    --
    + initialize(email:, password:)
    + call() : String (JWT)
    .. exceptions ..
    InvalidCredentials
  }

  class CreateNoteService <<Service>> {
    - client_params : Hash
    - note_params : Hash
    --
    + initialize(client_params:, note_params:)
    + call() : Note
    - find_or_create_client() : Client
    - validate_reliability!() : void
    - build_resource_params() : Hash
    .. exceptions ..
    ClientBlocked
  }

  class CompleteNoteService <<Service>> {
    - note : Note
    --
    + initialize(note)
    + call() : void
    .. exceptions ..
    InvalidStatus
  }

  class CancelNoteService <<Service>> {
    - note : Note
    --
    + initialize(note)
    + call() : void
    .. exceptions ..
    InvalidStatus
  }

  class ClientReliabilityService <<Service>> {
    - client : Client
    - {static} PERIOD : Duration = 3.months
    - {static} CANCELLATION_THRESHOLD : Integer = 10
    --
    + initialize(client)
    + call() : Boolean
    - cancellations_count() : Integer
  }

  class DiscontService <<Service>> {
    - note : Note
    - {static} FIRST_DISCONT_PERCENT : Integer = 10
    --
    + initialize(note)
    + call() : void
    - calculate_discont_price() : Float
  }

  class ConsumeMaterialsService <<Service>> {
    - note : Note
    --
    + initialize(note)
    + call() : void
  }

  class ReturnMaterialsService <<Service>> {
    - note : Note
    --
    + initialize(note)
    + call() : void
    - operations_to_return() : ActiveRecord::Relation
  }

  class MasterScheduleService <<Service>> {
    - master : Master
    --
    + initialize(master)
    + call() : Array<Hash>
  }

  class AvailableDatesService <<Service>> {
    - master : Master
    - days_count : Integer = 30
    --
    + initialize(master, days_count: 30)
    + call() : Array<Date>
    - working_day?(date) : Boolean
  }

  class AvailableSlotsService <<Service>> {
    - master : Master
    - date : Date
    - {static} STEP_MINUTES : Integer = 60
    --
    + initialize(master, date:)
    + call() : Array<String>
  }

  class "Materials::\nOperationsProvider" as OperationsProvider <<Service>> {
    - action : Symbol
    - params : Hash
    --
    + {static} call(action, params) : void
    - apply!() : void
    - confirm!() : void
    - cancel!() : void
    .. exceptions ..
    InvalidAction
    InvalidTransition
    NotEnoughMaterial
  }

  class PriceAnalysisService <<Service>> {
    - {static} ALPHA : Float = 0.05
    - {static} BETA : Float = 0.03
    --
    + call() : void
    - generate_months() : Array
    - preload_notes_data() : Hash
    - preload_first_visit_counts() : Hash
    - compute_material_costs() : Hash
    - write_csv() : void
  }

  class PriceAnalysisResultService <<Service>> {
    - {static} PREDICTIONS_PATH : Pathname
    --
    + call() : Hash
    - enrich_with_titles(predictions) : Array
    .. exceptions ..
    NotFound
  }

  class MaterialForecastService <<Service>> {
    --
    + call() : void
    - generate_months() : Array
    - preload_bookings() : Hash
    - compute_avg_bookings() : Hash
    - get_ratio() : Float
    - compute_trend() : Float
    - export_materials_json() : void
    - export_service_materials_json() : void
    - write_csv() : void
  }

  class MaterialForecastResultService <<Service>> {
    - {static} PREDICTIONS_PATH : Pathname
    --
    + call() : Hash
    .. exceptions ..
    NotFound
  }
}

' Service dependencies
SignInService ..> User : authenticates
CreateNoteService ..> ClientReliabilityService : validates
CreateNoteService ..> ConsumeMaterialsService : calls
CreateNoteService ..> DiscontService : calls
CreateNoteService ..> NoteResource : builds
CompleteNoteService ..> Note : updates status
CancelNoteService ..> ReturnMaterialsService : calls
ClientReliabilityService ..> Note : queries
DiscontService ..> Note : uses
ConsumeMaterialsService ..> Note : uses
ConsumeMaterialsService ..> OperationsProvider : calls
ReturnMaterialsService ..> Note : uses
ReturnMaterialsService ..> OperationsProvider : calls
MasterScheduleService ..> Master : uses
AvailableDatesService ..> Master : uses
AvailableSlotsService ..> Master : uses
OperationsProvider ..> Material : locks & updates
OperationsProvider ..> MaterialOperation : creates
PriceAnalysisService ..> Note : queries
PriceAnalysisService ..> Service : queries
PriceAnalysisResultService ..> Service : queries
MaterialForecastService ..> Note : queries
MaterialForecastService ..> Service : queries
MaterialForecastService ..> Material : queries


' ===== JOBS =====
package "Jobs" {

  class PriceAnalysisJob <<Job>> {
    - {static} VENV_PYTHON : Pathname
    - {static} TRAIN_SCRIPT : Pathname
    - {static} PREDICT_SCRIPT : Pathname
    --
    + perform() : void
    - run_script(script) : void
  }

  class MaterialForecastJob <<Job>> {
    - {static} VENV_PYTHON : Pathname
    - {static} TRAIN_SCRIPT : Pathname
    - {static} PREDICT_SCRIPT : Pathname
    --
    + perform() : void
    - run_script(script) : void
  }
}

PriceAnalysisJob ..> PriceAnalysisService : calls
PriceAnalysisJob ..> "ml/train_price.py" : executes
PriceAnalysisJob ..> "ml/predict_price.py" : executes

MaterialForecastJob ..> MaterialForecastService : calls
MaterialForecastJob ..> "ml/train_materials.py" : executes
MaterialForecastJob ..> "ml/predict_materials.py" : executes


' ===== CONTROLLERS =====
package "Controllers" {

  abstract class ApplicationController {
    # @current_user : User
    --
    # authenticate!() : void
  }

  class AuthController {
    .. skip_before_action: authenticate! ..
    --
    + sign_in() : JSON
    - sign_in_params() : Hash
  }

  class UsersController {
    --
    + index() : JSON:API
    + show() : JSON:API
    + create() : JSON:API
    + update() : JSON:API
    + destroy() : JSON:API
  }

  class MastersController {
    .. skip_before_action: authenticate! ..
    .. only: index, available_dates, available_slots ..
    --
    + index() : JSON:API
    + show() : JSON:API
    + create() : JSON:API
    + update() : JSON:API
    + destroy() : JSON:API
    + available_dates() : JSON
    + available_slots() : JSON
  }

  class ServicesController {
    .. skip_before_action: authenticate! ..
    .. only: index ..
    --
    + index() : JSON:API
    + create() : JSON:API
    + update() : JSON:API
  }

  class ClientsController {
    --
    + index() : JSON:API
    + show() : JSON:API
    + create() : JSON:API
    + update() : JSON:API
    + destroy() : JSON:API
  }

  class MaterialsController {
    --
    + index() : JSON:API
    + show() : JSON:API
    + create() : JSON:API
    + update() : JSON:API
    + destroy() : JSON:API
  }

  class NotesController {
    .. skip_before_action: authenticate! ..
    .. only: create ..
    --
    + index() : JSON:API
    + create() : JSON:API
    + complete() : JSON
    + cancel() : JSON
    - client_params() : Hash
    - note_params() : Hash
  }

  class "Materials::\nOperationsController" as MatOpsController {
    --
    + add() : JSON
    + subtract() : JSON
    - operation_params() : Hash
  }

  class ServiceMaterialsController {
    --
    + index() : JSON:API
    + create() : JSON:API
    + update() : JSON:API
    + destroy() : JSON:API
  }

  class ServiceMastersController {
    --
    + index() : JSON:API
    + create() : JSON:API
    + destroy() : JSON:API
  }

  class "Masters::\nSchedulesController" as SchedulesController {
    --
    + index() : JSON
    + create() : JSON
    + destroy() : 204
    - set_master() : void
    - schedule_params() : Hash
  }

  class PriceAnalysisController {
    --
    + create() : JSON
    + show() : JSON
  }

  class MaterialForecastController {
    --
    + create() : JSON
    + show() : JSON
  }
}

ApplicationController <|-- AuthController
ApplicationController <|-- UsersController
ApplicationController <|-- MastersController
ApplicationController <|-- ServicesController
ApplicationController <|-- ClientsController
ApplicationController <|-- MaterialsController
ApplicationController <|-- NotesController
ApplicationController <|-- MatOpsController
ApplicationController <|-- ServiceMaterialsController
ApplicationController <|-- ServiceMastersController
ApplicationController <|-- SchedulesController
ApplicationController <|-- PriceAnalysisController
ApplicationController <|-- MaterialForecastController

ApplicationController ..> JwtService : authenticate
AuthController ..> SignInService : uses
MastersController ..> AvailableDatesService : uses
MastersController ..> AvailableSlotsService : uses
NotesController ..> CreateNoteService : uses
NotesController ..> CompleteNoteService : uses
NotesController ..> CancelNoteService : uses
MatOpsController ..> OperationsProvider : uses
SchedulesController ..> MasterScheduleService : uses
PriceAnalysisController ..> PriceAnalysisJob : uses
PriceAnalysisController ..> PriceAnalysisResultService : uses
MaterialForecastController ..> MaterialForecastJob : uses
MaterialForecastController ..> MaterialForecastResultService : uses


' ===== RESOURCES (Graphiti) =====
package "Resources (Graphiti)" {

  abstract class ApplicationResource {
    --
    adapter: ActiveRecord
    endpoint_namespace: /api
    default_page_size: 1000
  }

  class UserResource {
    --
    email, phone, active
    password (write-only)
    password_confirmation (write-only)
  }

  class MasterResource {
    --
    first_name, middle_name, last_name
    phone, active
    salary (write-only)
    full_name (computed)
    .. filters ..
    service_id (eq)
  }

  class ServiceResource {
    --
    title, description, duration
    price, active
    .. relationships ..
    has_many: service_materials
  }

  class ClientResource {
    --
    full_name, phone, telegram
  }

  class NoteResource {
    --
    status, total_price
    service_id, client_id, master_id
    start_at, end_at
    client_name (computed)
    master_name (computed)
    service_title (computed)
    .. relationships ..
    belongs_to: client, master, service
    .. filters ..
    date (eq)
    .. sort ..
    start_at
  }

  class MaterialResource {
    --
    title, quantity
    minimal_quantity, price
    .. relationships ..
    has_many: service_materials
  }

  class ServiceMaterialResource {
    --
    required_quantity
    service_id, material_id
    material_title (computed)
    .. relationships ..
    belongs_to: service, material
    .. filters ..
    service_id (eq)
  }

  class ServiceMasterResource {
    --
    service_id, master_id
    master_name (computed)
    .. relationships ..
    belongs_to: service, master
    .. filters ..
    service_id (eq)
  }
}

ApplicationResource <|-- UserResource
ApplicationResource <|-- MasterResource
ApplicationResource <|-- ServiceResource
ApplicationResource <|-- ClientResource
ApplicationResource <|-- NoteResource
ApplicationResource <|-- MaterialResource
ApplicationResource <|-- ServiceMaterialResource
ApplicationResource <|-- ServiceMasterResource

UserResource ..> User : serializes
MasterResource ..> Master : serializes
ServiceResource ..> Service : serializes
ClientResource ..> Client : serializes
NoteResource ..> Note : serializes
MaterialResource ..> Material : serializes
ServiceMaterialResource ..> ServiceMaterial : serializes
ServiceMasterResource ..> ServiceMaster : serializes

@enduml
