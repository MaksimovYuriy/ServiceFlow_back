@startuml Architecture Overview

skinparam componentFontSize 14
skinparam packageFontSize 16
skinparam arrowFontSize 12
skinparam defaultTextAlignment center
skinparam packageStyle rectangle

package "Controllers" as ctrl
package "Resources (Graphiti)" as res
package "Services" as svc
package "ML Services" as ml_svc
package "Jobs" as jobs
package "ML Pipeline (Python)" as ml
database "Models (ActiveRecord)" as models

ctrl --> res : JSON:API\nserialization
ctrl --> svc : business\nlogic
ctrl --> jobs : run\nanalysis
ctrl --> ml_svc : read\nresults

res --> models : ORM\nmapping

svc --> models : queries &\nupdates
svc --> svc : service\nchains

ml_svc --> models : queries

jobs --> ml_svc : export\nCSV/JSON
jobs --> ml : train &\npredict

ml ..> models : predictions\n(via tmp files)

@enduml
